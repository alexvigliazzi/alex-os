# ============================================
# Alex-OS .gitignore
# Exclui arquivos gerenciados pelo Claude Code
# ============================================

# Sistema Claude Code (nunca versionar)
sessions/
session-env/
file-history/
plugins/
cache/
plans/
shell-snapshots/
ide/
tasks/
telemetry/
paste-cache/
backups/
downloads/
scheduled-tasks/
projects/

# Credenciais e estado de sessao
*.credentials.json
.credentials.json
.claude.json
history.jsonl
security_warnings_state_*.json
mcp-needs-auth-cache.json
settings.local.json

# Memoria pessoal (cada instalacao tem a sua)
memory/*.md
!memory/.gitkeep

# Legacy
.claude-skills/

# Obsidian vault (120MB — sincronizado via OneDrive junction, nao vai para git)
brain/

# OS
.DS_Store
Thumbs.db
desktop.ini
*.swp
*.swo
*~

# Security artifacts
security/*.bak
security/*.MALWARE*
